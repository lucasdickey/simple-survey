# Every provider below is OPTIONAL. With none set, the app runs against a local
# SQLite file (file:local.db / file:local-contacts.db), the dashboard is open,
# and email + LLM features no-op. Fill these in to go to production.

# --- Turso — analytics DB (no PII) ---------------------------------------
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Turso — contacts DB (PII only) --------------------------------------
# REQUIRED once TURSO_DATABASE_URL is set: email/clerk-id must live in a
# physically separate database from analytics data. The app fails closed
# (throws) if the analytics DB is remote but this one is not.
CONTACTS_DATABASE_URL=
CONTACTS_AUTH_TOKEN=

# --- Clerk (optional; gates the /dashboard admin) ------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- OpenRouter (optional; chat mode + extraction + summaries) -----------
# Model ids are OpenRouter slugs (provider/model) so they swap with no code change.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_CHAT_MODEL=anthropic/claude-haiku-4.5

# --- SendGrid (optional; admin notification on submit) -------------------
SENDGRID_API_KEY=
SENDGRID_FROM=
